# Copy this file to ".env" and fill in real values.
# You'll get the Band key + partner codes at the June 12 kickoff.
# The ".env" file is gitignored, so your secrets won't be committed.

# --- Band (the agent coordination platform) ---
BAND_API_KEY=
BAND_ROOM_ID=

# --- OpenAI (for Band's SDK quickstart / fallback LLM) ---
# Get yours at platform.openai.com -> API keys. Shown only once - paste it here right away.
OPENAI_API_KEY=

# --- Model provider: AI/ML API (OpenAI-compatible) ---
# Key / promo code announced at kickoff ($10 credit).
AIML_API_KEY=
AIML_BASE_URL=https://api.aimlapi.com/v1   # example — verify in AI/ML API docs

# --- Featherless (open-source models; $25 promo code at kickoff) ---
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1

# Cross-provider review: each reviewer can use a different model family while
# keeping the no-key simulation path stable.
CORRECTNESS_MODEL=google/gemini-2.5-flash
CORRECTNESS_PROVIDER=aiml
SECURITY_MODEL=Qwen/Qwen2.5-72B-Instruct
SECURITY_PROVIDER=featherless
LEAD_MODEL=gpt-4o
LEAD_PROVIDER=aiml
TEST_MODEL=google/gemini-2.5-flash
TEST_PROVIDER=aiml

# What to review: a real public GitHub PR (Increment 2).
# Set both to review a live PR; leave blank to review the built-in sample diff.
REVIEW_REPO=          # e.g. kgotsonceba/autoreview-demo
REVIEW_PR=            # e.g. 1
